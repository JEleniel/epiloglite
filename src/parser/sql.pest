// Characters:
ampersand    = { "&" }
asterisk     = { "*" }
at           = { "@" }
circumflex   = { "^" }
colon        = { ":" }
comma        = { "," }
dollar       = { "$" }
dot          = { "." }
double_quote = { "\x22" }
equal        = { "=" }
exclamation  = { "!" }
grave        = { "`" }
gt           = { ">" }
lcb          = { "{" }
lparen       = { "(" }
lsb          = { "[" }
lt           = { "<" }
minus        = { "-" }
octothorpe   = { "#" }
percent      = { "%" }
plus         = { "+" }
question     = { "?" }
rcb          = { "}" }
rparen       = { ")" }
rsb          = { "]" }
rsolidus     = { "\\" }
semi         = { ";" }
single_quote = { "'" }
solidus      = { "/" }
tilde        = { "~" }
underscore   = { "_" }
vertical_bar = { "|" }
